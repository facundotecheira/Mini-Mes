<Window x:Class="GateWay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GateWay - OPC UA Client" Height="560" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Paleta -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2E5AAC"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1F3F7A"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#C0392B"/>
        <SolidColorBrush x:Key="DangerDarkBrush" Color="#962D22"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#D0D5DD"/>
        <SolidColorBrush x:Key="CardBrush" Color="White"/>

        <!-- Estilo de Labels -->
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>

        <!-- Estilo de TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Estilo de CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Estilo base de botones -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#6C757D"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Título -->
            <RowDefinition Height="Auto"/>
            <!-- Card conexión -->
            <RowDefinition Height="Auto"/>
            <!-- Card filtro -->
            <RowDefinition Height="*"/>
            <!-- Tree + acciones -->
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <TextBlock Grid.Row="0" Text="Cliente OPC UA"
                   FontSize="20" FontWeight="Bold"
                   Foreground="#1F2937" Margin="0,0,0,12"/>

        <!-- Card: Conexión -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                    <Label Content="OPC UA URL"/>
                    <TextBox x:Name="txtUrl" Text=""/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10" VerticalAlignment="Bottom">
                    <Button x:Name="btnConnect" Content="Conectar"
                            Style="{StaticResource PrimaryButton}"
                            Width="100" Height="32" Click="btnConnect_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10" VerticalAlignment="Bottom">
                    <Button x:Name="btnDisconnect" Content="Desconectar"
                            Style="{StaticResource DangerButton}"
                            Width="100" Height="32" Click="btnDisconnect_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                    <Label Content="Nombre Máquina"/>
                    <TextBox x:Name="txtPlcName"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Card: Filtro -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <Label Content="Filtrar Nodo"/>
                    <TextBox x:Name="txtFilterNode"/>
                </StackPanel>

                <CheckBox x:Name="checkAllTree" Content="Solo Nodo" Margin="424,25,23,0" Height="30" VerticalAlignment="Top"/>

                <Button x:Name="btnFilterNode" Content="Filtrar"
                        Style="{StaticResource SecondaryButton}"
                        Grid.Column="2" Width="90" Height="30"
                        VerticalAlignment="Top" Click="FilterNode_Click" Margin="0,17,0,0"/>
            </Grid>
        </Border>

        <!-- Árbol de nodos + acciones -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                    CornerRadius="6" Padding="4">
                <TreeView x:Name="tvNodos" BorderThickness="0" Background="Transparent">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="btnSuscribe" Content="Suscribir"
                        Style="{StaticResource PrimaryButton}"
                        Width="110" Height="34" Margin="0,0,10,0"
                        Click="btnSuscribe_Click"/>
                <Button x:Name="btnShowMonitoringWindow" Content="Ventana de Monitoreo"
                        Style="{StaticResource SecondaryButton}"
                        Width="180" Height="34"
                        Click="btnShowMonitoringWindow_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>